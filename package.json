{
  "name": "comins-grid-layout",
  "version": "0.1.3",
  "type": "module",
  "scripts": {
    "dev": "vite --config vite.example.config.ts",
    "build": "vite build && tsc -p tsconfig.build.json && cp src/styles.css dist/styles.css",
    "check:security": "node scripts/check-public-identities.mjs",
    "typecheck": "tsc --noEmit",
    "lint": "tsc --noEmit",
    "setup:hooks": "git config core.hooksPath .githooks",
    "test": "vitest",
    "test:consumer": "node scripts/consumer-smoke.mjs",
    "test:run": "vitest run",
    "test:security": "node --test test/security/*.node.mjs",
    "test:e2e": "env -u NO_COLOR playwright test --config=playwright.config.ts",
    "verify": "npm run test:security && npm run lint && npm run test:run && npm run build",
    "verify:e2e": "npm run test:e2e",
    "verify:full": "npm run verify && npm run verify:e2e",
    "verify:package-artifact": "node scripts/verify-package-artifact.mjs"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./styles.css": "./dist/styles.css"
  },
  "files": [
    "dist",
    "README.md",
    "CHANGELOG.md"
  ],
  "sideEffects": [
    "./dist/styles.css"
  ],
  "dependencies": {
    "gridstack": "^12.6.0",
    "lucide-react": "^1.11.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@types/node": "^26.1.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "prism-react-renderer": "^2.4.1",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-router": "^7.17.0",
    "typescript": "^6.0.3",
    "vite": "^8.1.4",
    "vitest": "^4.1.10"
  },
  "peerDependencies": {
    "react": ">=18.0.0 <20.0.0",
    "react-dom": ">=18.0.0 <20.0.0"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/kim1124/comins-layout.git"
  },
  "bugs": {
    "url": "https://github.com/kim1124/comins-layout/issues"
  },
  "homepage": "https://github.com/kim1124/comins-layout#readme"
}
